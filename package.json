{
  "name": "tracer",
  "version": "0.1.2",
  "description": "Tracer — Filesystem Graph Explorer for macOS",
  "private": true,
  "scripts": {
    "dev": "npx tauri dev",
    "build": "npm run build:ts && npx tauri build",
    "build:ts": "tsc",
    "watch:ts": "tsc --watch",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "filesystem",
    "node-graph",
    "visualization",
    "macos",
    "tauri",
    "rust"
  ],
  "author": "suraj-v23",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suraj-v23/tracer"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
