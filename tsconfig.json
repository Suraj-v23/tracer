{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "allowJs": false,
    "outDir": "./static/js",
    "rootDir": "./static/js"
  },
  "include": ["static/js/**/*.ts"],
  "exclude": ["static/js/**/*.test.ts", "node_modules"]
}
