{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "allowJs": false,
    "outDir": "./frontend/js",
    "rootDir": "./frontend/js"
  },
  "include": ["frontend/js/**/*.ts"],
  "exclude": ["frontend/js/**/*.test.ts", "node_modules"]
}
